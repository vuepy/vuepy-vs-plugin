{
  "name": "vuepy",
  "displayName": "Vuepy",
  "description": "Language support for Vuepy",
  "version": "0.0.1",
  "publisher": "vuepy-org",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vuepy.runVueFile",
        "title": "▶ Run Vuepy file",
        "icon": "$(play)"
      },
      {
        "command": "vuepy.debugVueFile",
        "title": "Debug Vuepy file",
        "icon": "$(debug-alt)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "vuepy.runVueFile",
          "when": "resourceExtname == .vue && vuepy.hasScriptPy",
          "group": "navigation@1"
        },
        {
          "command": "vuepy.debugVueFile",
          "when": "resourceExtname == .vue && vuepy.hasScriptPy",
          "group": "navigation@2"
        }
      ]
    },
    "grammars": [
      {
        "scopeName": "vue.injections.python",
        "path": "./syntaxes/vue-python.tmLanguage.json",
        "injectTo": [
          "source.vue",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "source.python": "python"
        }
      },
      {
        "scopeName": "vue.injections.pnmarkdown",
        "path": "./syntaxes/vue-pnmarkdown.tmLanguage.json",
        "injectTo": [
          "source.vue",
          "text.html.vue",
          "text.html.derivative"
        ],
        "embeddedLanguages": {
          "text.html.markdown": "markdown",
          "source.python": "python",
          "source.json": "json",
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.shell": "shellscript",
          "text.html.basic": "html",
          "source.css": "css",
          "source.yaml": "yaml"
        }
      }
    ]
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "icon": "icon.png",
  "main": "extension.js",
  "activationEvents": [
    "onLanguage:vue"
  ],
  "extensionDependencies": [
    "ms-python.python",
    "Vue.volar"
  ]
}